      "cwd": "hinde-site"
    },
    {
      "name": "Next.js production server (na build)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3000,
      "cwd": "hinde-site"
    }
  ]
}
