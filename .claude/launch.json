{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js dev server (homepage + admin + winkel)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "hinde-site"
    },
    {
      "name": "Next.js production build (lokaal)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build"],
