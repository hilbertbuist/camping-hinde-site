{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "buildCommand": "next build",
  "functions": {
    "src/app/(payload)/admin/[[...segments]]/page.tsx": {
      "maxDuration": 60
    },
    "src/app/(payload)/api/[...slug]/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/bread-orders/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/bread-orders",
      "schedule": "30 18 * * *"
    }
  ]
}
