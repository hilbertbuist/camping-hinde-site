# Payload CMS
PAYLOAD_SECRET=long-random-string-min-32-characters
DATABASE_URI=file:./payload.db

# Mollie betalingen (laat leeg in dev)
MOLLIE_API_KEY=

# SMTP configuratie (mijndomein.nl)
# Kopieer dit bestand naar .env.local en vul de waarden in.
# Op Vercel: voeg deze variabelen toe via Project Settings > Environment Variables.

SMTP_HOST=smtp.mijndomein.nl
SMTP_PORT=587
SMTP_USER=info@campingdehinde.nl
SMTP_PASS=jouw-wachtwoord-hier
MAIL_FROM="Boerderijcamping De Hinde <info@campingdehinde.nl>"
MAIL_TO=info@campingdehinde.nl
